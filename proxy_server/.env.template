# Environment Variables Template for Proxy Server
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration (comma-separated list of allowed origins)
# For mobile app, you might want to allow all origins with *
# For web deployment, specify your domain(s)
ALLOWED_ORIGINS=*

# Logging Configuration
LOG_LEVEL=info

# Qualtrics API Configuration
# Get your API token from: Account Settings > Qualtrics IDs > API Token
QUALTRICS_API_TOKEN=your_api_token_here
QUALTRICS_SURVEY_ID=SV_81uhgIyzv52qgdM

# Optional: Override individual survey URLs (DEPRECATED - use single survey above)
# QUALTRICS_INITIAL_URL=https://pretoria.eu.qualtrics.com/jfe/form/SV_aflSCXazOJiTkqy
# QUALTRICS_BIWEEKLY_URL=https://pretoria.eu.qualtrics.com/jfe/form/SV_0D4JPS2pOapx5lk  
# QUALTRICS_CONSENT_URL=https://pretoria.eu.qualtrics.com/jfe/form/SV_3OXso1SLL2yte8C

# Health Check Configuration
HEALTH_CHECK_TOKEN=your-secret-token-here

# Request Limits
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# Security Headers (optional overrides)
# CONTENT_SECURITY_POLICY=default-src 'self'
# X_FRAME_OPTIONS=DENY

# AWS Lambda specific (for Lambda deployment)
AWS_REGION=af-south-1
LAMBDA_FUNCTION_NAME=gauteng-wellbeing-proxy

# Monitoring (optional)
# SENTRY_DSN=your-sentry-dsn-here
# NEW_RELIC_LICENSE_KEY=your-new-relic-key-here