{
  "name": "gauteng-wellbeing-proxy",
  "version": "1.0.0",
  "description": "Secure proxy server for encrypted survey data submission to Qualtrics",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/test-proxy.js",
    "test:local": "node test/test-proxy.js http://localhost:3000",
    "test:deploy": "node test/test-proxy.js $PROXY_URL",
    "deploy:aws": "cd deploy && npm run package && aws lambda update-function-code --function-name gauteng-wellbeing-proxy --zip-file fileb://proxy.zip",
    "deploy:vercel": "vercel deploy"
  },
  "keywords": [
    "proxy",
    "encryption",
    "survey",
    "qualtrics",
    "research",
    "security"
  ],
  "author": "Gauteng Wellbeing Mapper Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "ActivitySpaceLab/gauteng-wellbeing-mapper-app"
  }
}