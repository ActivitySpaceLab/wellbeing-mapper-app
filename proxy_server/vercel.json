{
  "version": 2,
  "name": "gauteng-wellbeing-proxy",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ALLOWED_ORIGINS": "*"
  },
  "regions": ["bru1"],
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  }
}