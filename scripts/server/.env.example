# Production environment configuration
NODE_ENV=production
PORT=3000

# Database connection
DATABASE_URL=postgresql://barcelona_user:secure_password_here@localhost:5432/barcelona_research

# Security
API_KEY=your-secure-api-key-generate-new-one
PRIVATE_KEY_PATH=/opt/keys/barcelona_private_key.pem

# Study configuration  
STUDY_ID=barcelona_study_2025

# CORS settings (comma-separated origins)
ALLOWED_ORIGINS=https://your-research-domain.com

# Logging level
LOG_LEVEL=info