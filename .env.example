# Example Environment Variables Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT COMMIT THE ACTUAL .env FILE TO VERSION CONTROL

# Qualtrics API Configuration
QUALTRICS_API_TOKEN=your_actual_token_here
QUALTRICS_BASE_URL=https://pretoria.eu.qualtrics.com

# Instructions:
# 1. Copy this file to .env (without .example)
# 2. Replace 'your_actual_token_here' with your real Qualtrics API token
# 3. NEVER commit the .env file to git - it's in .gitignore for security
