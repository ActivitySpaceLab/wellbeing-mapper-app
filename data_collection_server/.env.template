# Environment variables for the Wellbeing Mapper data collection server.
# Copy this file to .env and adjust values for your deployment.

# Server configuration
NODE_ENV=production
PORT=3000

# CORS configuration (comma-separated list of allowed origins, or *).
ALLOWED_ORIGINS=*

# Filesystem path where received encrypted blobs are persisted.
# On serverless platforms, set this to a writable path (e.g. /tmp/received).
STORAGE_DIR=./received

# Request limits
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# AWS Lambda specific (only used by the deploy script)
AWS_REGION=eu-west-1
LAMBDA_FUNCTION_NAME=wellbeing-mapper-data-collection
