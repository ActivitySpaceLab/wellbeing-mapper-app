{
  "name": "wellbeing-mapper-data-collection-server",
  "version": "2.0.0",
  "description": "Data collection server for the Wellbeing Mapper app. Receives encrypted survey, consent, and location blobs and persists them for offline decryption by the research team.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/test-server.js",
    "test:local": "node test/test-server.js http://localhost:3000",
    "test:deploy": "node test/test-server.js $SERVER_URL",
    "deploy:vercel": "vercel deploy"
  },
  "keywords": [
    "encryption",
    "survey",
    "research",
    "wellbeing-mapper",
    "data-collection"
  ],
  "author": "ActivitySpaceLab",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "ActivitySpaceLab/wellbeing-mapper-app"
  }
}
